{
  "name": "agentflow",
  "version": "0.1.0",
  "description": "AgentFlow DSL — declarative language for multi-agent orchestration",
  "type": "module",
  "bin": {
    "agentflow": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "mcp": "tsx src/mcp-server.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "check:all": "tsx src/cli.ts check examples/code-quality.aflow && tsx src/cli.ts check examples/custom-domain.aflow"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
