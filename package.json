{
  "name": "@anhonestboy/agentflow",
  "version": "1.0.16",
  "description": "AgentFlow DSL — declarative language for composing multi-agent AI workflows. Write .aflow files, expose them as MCP tools. No integration code required.",
  "type": "module",
  "license": "MIT",
  "author": "Maurizio Palumbo <maurizio@madcity.it>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anhonestboy/agentflow.git"
  },
  "homepage": "https://github.com/anhonestboy/agentflow#readme",
  "bugs": {
    "url": "https://github.com/anhonestboy/agentflow/issues"
  },
  "keywords": [
    "agentflow",
    "dsl",
    "multi-agent",
    "orchestration",
    "mcp",
    "model-context-protocol",
    "llm",
    "ai",
    "workflow",
    "claude-code",
    "declarative",
    "agent"
  ],
  "bin": {
    "agentflow": "bin/agentflow.js",
    "agentflow-mcp": "bin/agentflow-mcp.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./mcp": "./dist/mcp-server.js"
  },
  "files": [
    "bin/",
    "dist/",
    "examples/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "mcp": "tsx src/mcp-server.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "check:all": "tsx src/cli.ts check examples/code-quality.aflow && tsx src/cli.ts check examples/custom-domain.aflow",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@inquirer/input": "^4.3.1",
    "@inquirer/prompts": "^7.10.1",
    "@inquirer/select": "^4.4.2",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^17.4.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.0.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
